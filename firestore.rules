rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isPlatformAdmin() {
      return request.auth != null && (
        request.auth.token.platformAdmin == true ||
        exists(/databases/$(database)/documents/platformAdmins/$(request.auth.token.email))
      );
    }

    function isStoreAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isTenantAdmin(tenantId) {
      return request.auth != null
        && request.auth.token.admin == true
        && request.auth.token.tenantId == tenantId;
    }

    match /platformAdmins/{email} {
      allow read, write: if isPlatformAdmin();
    }

    match /stores/{storeId} {
      allow read, write: if isPlatformAdmin();

      match /private/{doc} {
        allow read, write: if isPlatformAdmin();
      }
    }

    match /billingAccounts/{accountId} {
      allow read, write: if isPlatformAdmin();
    }

    // Shared-Shard Storefront Collections scoped per tenant
    match /tenants/{tenantId} {

      match /products/{productId} {
        allow read: if true;
        allow write: if isPlatformAdmin() || isTenantAdmin(tenantId);

        match /variants/{variantId} {
          allow read: if true;
          allow write: if isPlatformAdmin() || isTenantAdmin(tenantId);
        }
      }

      match /categories/{categoryId} {
        allow read: if true;
        allow write: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /settings/{docId} {
        allow read: if true;
        allow write: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /attributes/{docId} {
        allow read: if true;
        allow write: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /siteContent/{docId} {
        allow read: if true;
        allow write: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /pages/{docId} {
        allow read: if true;
        allow write: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /configuracion/{docId} {
        allow read: if true;
        allow write: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /orders/{orderId} {
        allow get, create: if true;
        allow list, update, delete: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /mail/{docId} {
        allow read, write: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /clients/{clientId} {
        allow read: if isPlatformAdmin() || isTenantAdmin(tenantId);
        allow write: if isPlatformAdmin();
      }

      match /users/{userId} {
        allow read: if (request.auth != null && request.auth.uid == userId) || isPlatformAdmin() || isTenantAdmin(tenantId);
        allow create: if request.auth != null && request.auth.uid == userId;
        allow update: if (request.auth != null && request.auth.uid == userId) || isPlatformAdmin() || isTenantAdmin(tenantId);
        allow delete: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
        allow update, delete: if request.auth != null
          && (resource.data.userId == request.auth.uid || isPlatformAdmin() || isTenantAdmin(tenantId));
      }
    }

    // admin_roles at root with composite key {tenantId}_{email}; written by Admin SDK only
    match /admin_roles/{compositeId} {
      allow read: if isPlatformAdmin()
        || (isStoreAdmin() && compositeId.matches(request.auth.token.tenantId + '_.*'));
      allow write: if isPlatformAdmin();
    }
  }
}

