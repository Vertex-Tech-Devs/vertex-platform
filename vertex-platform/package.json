{
  "name": "vertex-platform",
  "version": "0.1.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:dev": "ng build --configuration=development",
    "build:prod": "ng build --configuration=production",
    "deploy:dev": "gcloud config configurations activate default && npm run clean && npm run build:dev && npm --prefix functions run build && firebase deploy --only hosting:dev,functions --project=vertex-platform-dev --force",
    "deploy:prod": "gcloud config configurations activate vertex-prod && npm run clean && npm run build:prod && npm --prefix functions run build && firebase deploy --only hosting:prod,functions --project=vertex-platform-app",
    "clean": "rm -rf dist functions/lib .angular/cache .firebase",
    "watch": "ng build --watch --configuration development",
    "prebuild": "npm run build --workspace=@vertex/contracts --if-present",
    "prebuild:dev": "npm run build --workspace=@vertex/contracts --if-present",
    "prebuild:prod": "npm run build --workspace=@vertex/contracts --if-present",
    "pretest": "npm run build --workspace=@vertex/contracts --if-present",
    "pretypecheck": "npm run build --workspace=@vertex/contracts --if-present",
    "test": "ng test",
    "lint": "ng lint",
    "typecheck": "tsc --noEmit",
    "validate:rules": "tsx scripts/validate-firestore-rules.ts",
    "qa": "tsx scripts/qa.ts",
    "qa:full": "tsx scripts/qa.ts --full",
    "e2e": "cypress open",
    "e2e:run": "cypress run --spec 'cypress/e2e/saas-integration.cy.ts'",
    "e2e:ci": "start-server-and-test start http-get://127.0.0.1:4200 'cypress run'",
    "test:integration": "playwright test --config integration-tests/playwright.config.ts",
    "test:integration:ui": "playwright test --ui --config integration-tests/playwright.config.ts",
    "test:integration:env": "bash scripts/start-integration-env.sh",
    "add-admin": "tsx scripts/add-admin.ts",
    "remove-admin": "tsx scripts/add-admin.ts --remove",
    "setup-provisioning": "tsx scripts/setup-provisioning.ts",
    "seed:stores": "tsx scripts/seed-existing-stores.ts",
    "register-shard": "tsx scripts/register-shard.ts",
    "test:provision": "bash scripts/verify-provision.sh",
    "test:email-delivery": "bash scripts/test-email-delivery.sh",
    "setup": "tsx scripts/setup.ts",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "overrides": {
    "brace-expansion": ">=2.0.1",
    "fast-uri": ">=3.1.2",
    "protobufjs": ">=7.5.8",
    "tmp": ">=0.2.6",
    "uuid": ">=11.1.1",
    "qs": ">=6.15.2",
    "esbuild": "^0.27.4",
    "vite": "^7.3.5",
    "@babel/core": "^7.29.7",
    "piscina": ">=5.2.0",
    "undici": "^7.27.3"
  },
  "dependencies": {
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@vertex/contracts": "*",
    "firebase": "^11.10.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/build": "^22.0.3",
    "@angular/cli": "^22.0.3",
    "@angular/compiler-cli": "^22.0.2",
    "@clack/prompts": "^1.6.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@google-cloud/secret-manager": "^6.2.0",
    "@playwright/test": "^1.61.0",
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "cypress": "^15.17.0",
    "eslint": "^9.39.4",
    "firebase-admin": "^14.0.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "start-server-and-test": "^3.0.11",
    "tsx": "^4.22.4",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.2"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "functions/src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "cypress/**/*.ts": [
      "prettier --write"
    ],
    "*.html": [
      "prettier --write"
    ],
    "*.scss": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "ci",
          "chore",
          "revert"
        ]
      ],
      "type-case": [
        2,
        "always",
        "lowercase"
      ],
      "type-empty": [
        2,
        "never"
      ],
      "scope-case": [
        2,
        "always",
        "lowercase"
      ]
    }
  }
}
