#!/bin/sh

COMMIT_MSG=$(cat "$1")
PATTERN="^(feat|fix|docs|style|refactor|perf|test|ci|chore|revert)(\(.+\))?: .{1,}"
MERGE_PATTERN="^Merge (branch|tag|remote-tracking branch|pull request) "

# Allow standard merge commits
if echo "$COMMIT_MSG" | grep -qE "$MERGE_PATTERN"; then
  exit 0
fi

if ! echo "$COMMIT_MSG" | grep -qE "$PATTERN"; then
  echo ""
  echo "❌ Invalid commit message format."
  echo ""
  echo "   Expected: <type>(<scope>): <description>"
  echo "   Example:  feat(auth): add login page"
  echo ""
  echo "   Allowed types: feat, fix, docs, style, refactor, perf, test, ci, chore, revert"
  echo ""
  echo "   Note: Standard merge commits (e.g., starting with 'Merge branch') are also allowed."
  echo ""
  exit 1
fi
