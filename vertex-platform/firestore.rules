rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones Helper de Gobernanza Global
    function isAuthenticated() {
      return request.auth != null;
    }

    function isPlatformAdmin() {
      return isAuthenticated() && 
        (request.auth.token.platformAdmin == true || request.auth.token.superAdmin == true);
    }

    function isTenantAdmin(tenantId) {
      return isAuthenticated() && 
        resource.data.tenantId == tenantId &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/admin_roles/$(request.auth.token.email)).data.role == 'admin';
    }

    // 1. Regla para Entornos Dedicados (Single Tenant / Enterprise)
    match /configuracion/store {
      allow read: if true;
      allow write: if isPlatformAdmin() || 
        (isAuthenticated() && get(/databases/$(database)/documents/admin_roles/$(request.auth.token.email)).data.role == 'admin');
    }

    // 2. Regla para Entornos Compartidos (Multi-Tenant Shards)
    match /tenants/{tenantId} {
      allow read, write: if isPlatformAdmin();

      match /configuracion/store {
        allow read: if true;
        allow write: if isPlatformAdmin() || isTenantAdmin(tenantId);
      }

      match /admin_roles/{email} {
        allow read: if isAuthenticated() && (request.auth.token.email == email || isPlatformAdmin());
        allow write: if isPlatformAdmin();
      }
    }
    
    // Protección por defecto de la factoría
    match /{document=**} {
      allow read, write: if isPlatformAdmin();
    }
  }
}
