# Firebase Cloud Functions Environment Variables (TEMPLATE)
# Copy this file to .env and fill in your actual values
# This file is tracked in git as a reference

# ============================================================================
# MercadoPago Payment Integration
# ============================================================================
# Get these from: https://www.mercadopago.com/developers/panel/credentials
# DO NOT commit your real token
MERCADOPAGO_ACCESSTOKEN=APP_USR-YOUR_TEST_TOKEN_HERE

# Webhook URL for payment notifications
# Format: https://your-project.cloudfunctions.net/mercadoPagoWebhookHandler
MERCADOPAGO_WEBHOOK_URL=https://us-central1-YOUR_APP.cloudfunctions.net/mercadoPagoWebhookHandler

# Frontend URL for post-payment redirect
SITE_URL=https://YOUR_APP.web.app

# ============================================================================
# IMPORTANT SECURITY NOTES
# ============================================================================
# 1. NEVER commit .env files with real credentials
# 2. Use `firebase functions:config:set` for production
# 3. Keep .env.* files in .gitignore (except .env.example)  
# 4. Use separate credentials for dev/staging/production
# 5. Rotate tokens immediately if exposed
