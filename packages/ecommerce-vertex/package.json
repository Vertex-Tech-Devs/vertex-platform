{
  "name": "ecommerce-vertex",
  "version": "1.0.0",
  "workspaces": [
    "packages/shared-contracts"
  ],
  "scripts": {
    "setup": "tsx scripts/setup.ts",
    "setup:credentials": "tsx scripts/setup-credentials.ts",
    "start": "ng serve",
    "build": "ng build --configuration production",
    "test": "ng test --watch=false --code-coverage",
    "fix": "eslint src --fix && prettier --write \"src/**/*.{ts,html,scss}\"",
    "qa": "tsx scripts/qa.ts",
    "qa:full": "tsx scripts/qa.ts --full",
    "verify:flows": "tsx scripts/verify-flows.ts",
    "security:scan": "npm audit --audit-level=moderate",
    "e2e": "cypress run --e2e",
    "e2e:open": "cypress open --e2e",
    "e2e:ci": "cypress run --e2e --browser chrome",
    "test:integration": "playwright test --config integration-tests/playwright.config.ts",
    "test:integration:ui": "playwright test --ui --config integration-tests/playwright.config.ts",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadlessCI --code-coverage",
    "deploy:dev": "npm run clean && npm run build:dev && npm run build:fn && firebase deploy --project development --only hosting:ecommerce-vertex,functions",
    "deploy:prod": "npm run clean && npm run build && npm run build:fn && firebase deploy --project production --only hosting:ecommerce-vertex,functions",
    "clean": "rm -rf dist functions/lib coverage",
    "prepare": "husky",
    "lint": "eslint src",
    "prebuild": "npm run build --workspace=@vertex/contracts --if-present",
    "prebuild:dev": "npm run build --workspace=@vertex/contracts --if-present",
    "pretest": "npm run build --workspace=@vertex/contracts --if-present",
    "pretest:ci": "npm run build --workspace=@vertex/contracts --if-present",
    "pretypecheck": "npm run build --workspace=@vertex/contracts --if-present",
    "typecheck": "tsc --noEmit",
    "build:dev": "ng build --configuration development",
    "build:fn": "npm run build --prefix functions",
    "postinstall": "([ ! -f src/environments/environment.ts ] && cp src/environments/environment.example.ts src/environments/environment.ts 2>/dev/null || true) && ([ ! -f src/firebase-config.json ] && cp src/firebase-config.example.json src/firebase-config.json 2>/dev/null || true) && ([ -z \"$CI\" ] && [ -d \"functions\" ] && (cd functions && npm install) || true)"
  },
  "dependencies": {
    "@angular/animations": "^20.3.21",
    "@angular/common": "^20.3.21",
    "@angular/compiler": "^20.3.21",
    "@angular/core": "^20.3.21",
    "@angular/fire": "^20.0.0",
    "@angular/forms": "^20.3.21",
    "@angular/platform-browser": "^20.3.21",
    "@angular/platform-browser-dynamic": "^20.3.21",
    "@angular/router": "^20.3.21",
    "@popperjs/core": "^2.11.8",
    "@vertex/contracts": "*",
    "bootstrap": "5.3.8",
    "bootstrap-icons": "1.13.1",
    "firebase": "^11.10.0",
    "ngx-bootstrap": "20.0.2",
    "ngx-quill": "^28.0.1",
    "quill": "^2.0.2",
    "rxjs": "^7.8.1",
    "sweetalert2": "^11.26.25",
    "tslib": "^2.6.2",
    "zod": "^3.22.4",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.0.0",
    "@angular-eslint/builder": "^20.0.0",
    "@angular-eslint/eslint-plugin": "^20.0.0",
    "@angular-eslint/eslint-plugin-template": "^20.0.0",
    "@angular-eslint/template-parser": "^20.0.0",
    "@angular/cli": "^20.3.26",
    "@angular/compiler-cli": "^20.3.21",
    "@clack/prompts": "^1.4.0",
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@playwright/test": "^1.60.0",
    "@types/jasmine": "^5.1.0",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.57.0",
    "cypress": "^14.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "http-proxy-agent": "^8.0.0",
    "husky": "^9.0.0",
    "is-core-module": "^2.16.2",
    "jasmine-core": "^5.1.0",
    "karma": "^6.4.0",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.0",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "lint-staged": "^15.0.0",
    "npm-force-resolutions": "^0.0.10",
    "prettier": "^3.8.3",
    "tsx": "^4.22.3",
    "typescript": "5.9.3"
  },
  "prettier": {
    "printWidth": 100,
    "tabWidth": 2,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "quoteProps": "as-needed",
    "jsxSingleQuote": false,
    "trailingComma": "es5",
    "bracketSpacing": true,
    "bracketSameLine": false,
    "arrowParens": "always",
    "htmlWhitespaceSensitivity": "css",
    "endOfLine": "lf"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "cypress/**/*.ts": [
      "prettier --write"
    ],
    "*.html": [
      "prettier --write"
    ],
    "*.scss": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "type-enum": [
        2,
        "always",
        [
          "feat",
          "fix",
          "docs",
          "style",
          "refactor",
          "perf",
          "test",
          "ci",
          "chore",
          "revert"
        ]
      ],
      "type-case": [
        2,
        "always",
        "lowercase"
      ],
      "type-empty": [
        2,
        "never"
      ],
      "scope-case": [
        2,
        "always",
        "lowercase"
      ],
      "subject-case": [
        2,
        "never",
        [
          "start-case",
          "pascal-case",
          "upper-case"
        ]
      ],
      "subject-empty": [
        2,
        "never"
      ],
      "subject-full-stop": [
        2,
        "never",
        "."
      ],
      "subject-exclamation-mark": [
        2,
        "never"
      ],
      "header-max-length": [
        2,
        "always",
        72
      ],
      "body-leading-blank": [
        2,
        "always"
      ],
      "footer-leading-blank": [
        2,
        "always"
      ],
      "footer-token-reference": [
        2,
        "always"
      ]
    }
  },
  "overrides": {
    "protobufjs": ">=7.5.8",
    "@protobufjs/utf8": ">=1.1.1",
    "ws": ">=8.20.1",
    "follow-redirects": ">=1.16.0",
    "postcss": ">=8.5.10",
    "fast-xml-parser": ">=5.7.0",
    "fast-uri": ">=3.1.2",
    "brace-expansion": ">=2.0.1"
  },
  "private": true
}
