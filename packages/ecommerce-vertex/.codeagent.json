{
  "projectName": "Vertex E-commerce",
  "version": "1.0.0",
  "lastUpdated": "2026-03-13",
  "agentRestrictions": {
    "gitCommands": "FORBIDDEN - Never use git push, git commit, git checkout, or any git operations",
    "versionManagement": "Update 'version' field ONLY after completing significant work",
    "documentation": "Update README.md only. DO NOT create new .md files",
    "testing": "REQUIRED - All features must have tests (70%+ min coverage)",
    "gitIgnore": "NO git touches ever. User will commit and push."
  },
  "codeStandards": {
    "language": "English",
    "languageVersion": "TypeScript 5.8+",
    "framework": "Angular 20",
    "strictMode": true,
    "modules": "ESM"
  },
  "codeRules": {
    "comments": {
      "strategy": "MINIMAL",
      "policy": "Only explain WHY, not WHAT. Code should be self-documenting.",
      "publicAPIs": "JSDoc for public methods/types only",
      "privateLogic": "No comments - name variables/functions clearly",
      "complexAlgorithms": "Brief explanation at function header"
    },
    "naming": {
      "variables": "camelCase",
      "constants": "UPPER_SNAKE_CASE",
      "types": "PascalCase",
      "files": "kebab-case for components, camelCase for utils",
      "naming.clarity": "Self-documenting names, no abbreviations"
    },
    "functions": {
      "maxLines": 40,
      "maxParameters": 5,
      "pure": "Prefer pure functions",
      "types": "Explicit parameter and return types (no 'any')"
    },
    "files": {
      "maxLines": 300,
      "organization": "Single responsibility per file",
      "imports": "Organized in groups: external, internal, types"
    },
    "async": {
      "preference": "Signals > RxJS Observables > Promises",
      "errorHandling": "Try-catch for promises, pipe(catchError) for observables",
      "noUnsubscribe": "Use takeUntilDestroyed or OnDestroy"
    }
  },
  "architecture": {
    "pattern": "Domain-Driven Design + Clean Architecture",
    "layers": {
      "presentation": "Components, directives, pipes",
      "domain": "Models, interfaces, business logic",
      "data": "Services, API calls, storage",
      "core": "Global services, guards, interceptors"
    },
    "structure": {
      "shared": "Reusable components, utilities, testing helpers",
      "core": "Services, models, guards, interceptors",
      "features": "Feature modules (admin, shop, etc)",
      "environments": "Environment configs"
    }
  },
  "testing": {
    "coverage": {
      "minimum": 70,
      "target": 80,
      "critical": 90
    },
    "strategy": {
      "unit": "All services, utilities, pure functions",
      "component": "Components except simple presenters",
      "e2e": "Critical user flows",
      "integration": "API calls and service interactions"
    },
    "frameworks": {
      "unit": "Jasmine",
      "e2e": "Cypress or Playwright",
      "runner": "Karma (unit), None (e2e via browsers)"
    }
  },
  "gitWorkflow": {
    "branches": {
      "main": "production code, requires PR + checks",
      "develop": "integration branch, requires PR + checks",
      "feature": "feature/description",
      "bugfix": "bugfix/description",
      "hotfix": "hotfix/description"
    },
    "commits": {
      "format": "Conventional Commits",
      "types": ["feat", "fix", "docs", "style", "refactor", "perf", "test", "ci", "chore"],
      "scope": "Module or feature",
      "example": "feat(auth): add two-factor authentication"
    },
    "pullRequests": {
      "required": true,
      "approvals": 1,
      "checks": ["unit-tests", "e2e-tests", "coverage", "build", "lint", "security"],
      "template": ".github/pull_request_template.md"
    }
  },
  "environments": {
    "development": {
      "branch": "develop",
      "checks": ["unit", "coverage", "build", "lint"],
      "deployment": false
    },
    "staging": {
      "branch": "staging",
      "checks": ["unit", "e2e", "coverage", "build", "lint", "security"],
      "deployment": "manual approval required"
    },
    "production": {
      "branch": "main",
      "checks": ["unit", "e2e", "coverage", "build", "lint", "security", "performance"],
      "deployment": "manual approval required"
    }
  },
  "qualityGates": {
    "unitTests": {
      "required": true,
      "minCoverage": 70,
      "mustPass": true
    },
    "e2eTests": {
      "required": true,
      "environments": ["staging", "production"],
      "mustPass": true
    },
    "linting": {
      "required": true,
      "strict": true,
      "autoFix": true
    },
    "typechecking": {
      "required": true,
      "strict": true,
      "noAny": true
    },
    "security": {
      "required": true,
      "audit": "npm audit --audit-level=high",
      "sast": true
    },
    "performance": {
      "bundleMaxSize": "500KB",
      "initialLoadMax": "2s"
    }
  },
  "tools": {
    "packageManager": "npm",
    "versionManager": "nvm",
    "linter": "ESLint",
    "formatter": "Prettier",
    "testRunner": "Karma (unit), Cypress (e2e)",
    "ci": "GitHub Actions",
    "preCommitHooks": "husky + lint-staged"
  },
  "conventions": {
    "exports": "Use named exports, avoid default exports",
    "imports": "Absolute imports via path aliases (@core, @shared, etc)",
    "services": "Inject via constructor, use providedIn: 'root'",
    "observables": "End with $ suffix",
    "signals": "No special suffix, infer from context",
    "types": "Use interfaces for objects, types for unions/primitives"
  },
  "deprecations": {
    "avoid": ["any type", "console.log", "setTimeout/setInterval", "nested subscriptions"],
    "replaceWith": ["typed parameters", "logger service", "scheduled tasks/signals", "takeUntil"]
  },
  "performance": {
    "changeDetection": "OnPush for all components",
    "bundleSplitting": "Lazy-loaded feature modules",
    "tracking": "Google Analytics via service"
  }
}
