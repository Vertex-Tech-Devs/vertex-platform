    "firebase-functions": "^6.0.0",
    "google-auth-library": "^9.0.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
