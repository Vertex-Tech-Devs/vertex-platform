#!/bin/sh
set -e

BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "develop" ]; then
  if [ "$ALLOW_DIRECT_PUSH" != "true" ]; then
    echo ""
    echo "✖ Direct push to $BRANCH is not allowed."
    echo "  Please open a PR from a feature branch."
    echo "  To bypass this protection (for automation/agent), set ALLOW_DIRECT_PUSH=true."
    echo ""
    exit 1
  else
    echo "✔ ALLOW_DIRECT_PUSH=true detected. Bypassing branch protection."
  fi
fi

echo ""
echo "Running strict pre-push quality gates..."
echo ""

# 1. Prettier check
echo "Checking formatting with Prettier..."
npx prettier --check "src/**/*.{ts,html,scss}" "functions/src/**/*.ts"

# 2. Lint check
echo "Running ESLint..."
npm run lint

# 3. Typecheck
echo "Running type check..."
npm run typecheck

# 4. Frontend tests
echo "Running frontend tests..."
npm run test -- --watch=false --reporters=default --coverage

# 5. Functions/Backend tests
echo "Running backend/functions tests..."
npm --prefix functions run test:coverage

# 6. Verify statement coverage (>=85%)
echo "Verifying coverage threshold >=85%..."
node scripts/verify-coverage.js

echo ""
echo "✔ All quality gates passed! Proceeding with push."
echo ""
