{
  "name": "vertex-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "vertex-platform",
    "packages/ecommerce-vertex",
    "packages/shared-contracts"
  ],
  "scripts": {
    "start": "tsx scripts/dev-e2e.ts",
    "dev:e2e": "tsx scripts/dev-e2e.ts",
    "sync-context": "tsx scripts/sync-ai-context.ts",
    "lint": "npm run lint --workspaces --if-present",
