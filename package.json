{
  "name": "vertex-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "vertex-platform",
    "packages/shared-contracts"
  ],
  "scripts": {
    "start": "tsx scripts/dev-e2e.ts",
    "dev:e2e": "tsx scripts/dev-e2e.ts",
    "sync-context": "tsx scripts/sync-ai-context.ts",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run build --workspace=@vertex/contracts --if-present && npm run typecheck --workspaces --if-present",
    "test": "npm run test:frontend && npm run test:backend",
    "test:frontend": "npm run build --workspace=@vertex/contracts --if-present && npm run test --workspace=vertex-platform",
    "test:backend": "npm run test --prefix vertex-platform/functions",
    "qa:global": "npm run validate:rules && npm run lint && npm run typecheck",
    "validate:rules": "npm run validate:rules --workspace=vertex-platform",
    "qa:full": "npm run lint && npm run typecheck && npm run test",
    "e2e": "npm run e2e --workspace=vertex-platform",
    "e2e:run": "npm run e2e:run --workspace=vertex-platform",
    "build": "npm run build --workspace=vertex-platform && npm run build --prefix vertex-platform/functions",
    "prepare": "husky"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^22.0.0",
    "@angular-eslint/eslint-plugin": "^22.0.0",
    "@angular-eslint/eslint-plugin-template": "^22.0.0",
    "@angular-eslint/template-parser": "^22.0.0",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@babel/core": "^7.29.7",
    "qs": "^6.15.2",
    "quill": "2.0.2",
    "uuid": "^11.1.1",
    "ws": ">=8.20.1",
    "vite": "^7.3.5",
    "esbuild": "0.28.1",
    "http-proxy-middleware": "^4.1.1",
    "piscina": "^5.2.0",
    "undici": "^7.27.3",
    "@angular/build": {
      ".": "22.0.3",
      "@angular/compiler-cli": "22.0.2",
      "@angular/compiler": "22.0.2",
      "@angular/core": "22.0.2",
      "esbuild": "0.28.1",
      "@babel/core": "^7.29.7",
      "piscina": "^5.2.0",
      "undici": ">=7.27.3"
    },
    "@angular/cli": "22.0.3",
    "@angular/compiler-cli": {
      ".": "22.0.2",
      "@babel/core": "^7.29.7"
    },
    "@angular-devkit/build-angular": {
      "esbuild": "0.28.1"
    },
    "tsx": {
      "esbuild": "0.28.1"
    }
  }
}
