{
  "name": "vertex-platform",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:dev": "ng build --configuration=development",
    "build:prod": "ng build --configuration=production",
    "deploy:dev": "gcloud config configurations activate default && npm run build:dev && firebase deploy --only hosting:dev,functions --project=vertex-platform-dev --force",
    "deploy:prod": "gcloud config configurations activate vertex-prod && npm run build:prod && firebase deploy --only hosting:prod,functions --project=vertex-platform-app",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "typecheck": "tsc --noEmit",
    "e2e": "cypress open",
    "e2e:ci": "start-server-and-test start http-get://127.0.0.1:4200 'cypress run'",
    "add-admin": "tsx scripts/add-admin.ts",
    "remove-admin": "tsx scripts/add-admin.ts --remove",
    "setup-provisioning": "tsx scripts/setup-provisioning.ts",
    "seed:stores": "tsx scripts/seed-existing-stores.ts",
    "register-shard": "tsx scripts/register-shard.ts"
  },
  "private": true,
  "packageManager": "npm@10.9.4",
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/fire": "^20.0.1",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "firebase": "^12.12.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular-eslint/builder": "^21.4.0",
    "@angular-eslint/eslint-plugin": "^21.4.0",
    "@angular-eslint/eslint-plugin-template": "^21.4.0",
    "@angular-eslint/template-parser": "^21.4.0",
    "@angular/build": "^21.2.9",
    "@angular/cli": "^21.2.9",
    "@angular/compiler-cli": "^21.2.0",
    "@google-cloud/secret-manager": "^5.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "cypress": "^14.5.4",
    "eslint": "^9.39.4",
    "firebase-admin": "^13.8.0",
    "jsdom": "^28.0.0",
    "prettier": "^3.8.1",
    "start-server-and-test": "^2.1.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
